# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/

# Native build output
native/llama.cpp/build/
native/llama.cpp/build-vulkan/

# llama-server.exe + DLLs (built by build/build-llama.cmd, not committed - the
# folder itself is tracked via .gitkeep so a fresh clone has somewhere to build into)
app/Engine/*
!app/Engine/.gitkeep

# Repo-local portable dev toolchain (tools/setup-workspace.cmd downloads these -
# never commit them, they're multi-hundred-MB and machine-specific)
tools/python/
tools/cmake/
tools/w64devkit/
tools/VulkanSDK/
tools/_downloads/

# Models (large binaries, never commit)
models/
*.gguf

# Local app data (chat DB, logs) if run from repo during dev
*.db
*.db-shm
*.db-wal
logs/

# Misc
*.log
.DS_Store
Thumbs.db
