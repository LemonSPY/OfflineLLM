<Window
    x:Class="OfflineLlm.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid ColumnDefinitions="280,*">

        <!-- Sidebar: saved chats + mode switcher -->
        <Grid Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="OfflineLLM" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                <Button Content="New saved chat" Click="OnNewSavedChatClick" />
                <Button Content="New offline chat" Click="OnNewOfflineChatClick" />
            </StackPanel>

            <ListView Grid.Row="2" x:Name="SavedChatsList"
                      SelectionChanged="OnSavedChatSelected"
                      ItemsSource="{x:Bind ViewModel.SavedSessions, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto" Padding="4">
                            <TextBlock Grid.Column="0" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                            <Button Grid.Column="1" Content="&#8942;" Style="{StaticResource TextBlockButtonStyle}"
                                    Click="OnSessionOverflowClick" Tag="{Binding}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ToggleSwitch Grid.Row="3" x:Name="ShowArchivedToggle" Header="Show archived"
                          Toggled="OnShowArchivedToggled" />
        </Grid>

        <!-- Chat panel -->
        <Grid Grid.Column="1" Padding="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
                <TextBlock Text="{x:Bind ViewModel.CurrentModeLabel, Mode=OneWay}"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <ComboBox x:Name="ModelPicker"
                          ItemsSource="{x:Bind ViewModel.AvailableModels, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedModel, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          PlaceholderText="Select a model" />
            </StackPanel>

            <ListView Grid.Row="1" x:Name="MessagesList"
                      ItemsSource="{x:Bind ViewModel.CurrentMessages, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,4" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                <TextBox Grid.Column="0" x:Name="MessageInput" PlaceholderText="Message..."
                         AcceptsReturn="False" KeyDown="OnMessageInputKeyDown" />
                <Button Grid.Column="1" Content="Send" Click="OnSendClick" Margin="8,0,0,0" />
            </Grid>
        </Grid>
    </Grid>
</Window>
