<ContentDialog
    x:Class="OfflineLlm.App.DownloadModelsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Download a model"
    PrimaryButtonText="Close"
    DefaultButton="Close">

    <StackPanel Spacing="12" Width="480">

        <TextBlock Text="Pick one, or paste a direct .gguf URL below." TextWrapping="Wrap" />

        <ListView x:Name="CatalogList"
                  ItemsSource="{x:Bind ViewModel.DownloadableModels}"
                  MaxHeight="260"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto" Padding="4" ColumnSpacing="8">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.8" FontSize="12" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Download" Click="OnDownloadCatalogEntryClick" Tag="{Binding}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Text="Custom .gguf URL" FontWeight="SemiBold" />
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0" x:Name="CustomUrlInput" PlaceholderText="https://.../model.gguf" />
            <Button Grid.Column="1" Content="Download" Click="OnDownloadCustomUrlClick" />
        </Grid>

        <StackPanel Visibility="{x:Bind ViewModel.IsDownloading, Mode=OneWay}" Spacing="4">
            <ProgressBar Value="{x:Bind ViewModel.DownloadFraction, Mode=OneWay}" Minimum="0" Maximum="1" />
            <TextBlock Text="{x:Bind ViewModel.DownloadStatusText, Mode=OneWay}" FontSize="12" />
        </StackPanel>

    </StackPanel>
</ContentDialog>
