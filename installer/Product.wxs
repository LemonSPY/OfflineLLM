<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="OfflineLLM"
           Manufacturer="OfflineLLM"
           Version="1.0.0.0"
           UpgradeCode="9d3f3a2e-9a2b-4e4d-9d5a-2b7a6f0a1c11"
           Language="1033"
           Scope="perUserOrMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of OfflineLLM is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!--
      $(var.AppPublishDir) : output of `dotnet publish` for OfflineLlm.App
                              (self-contained, includes engine\llama-server.exe + DLLs)
      $(var.AppIcon)        : path to src/OfflineLlm.App/Assets/app.ico
      Both are passed in via -d on the wix build command line (see build-installer.cmd).
    -->

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OfflineLLM" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppProgramMenuFolder" Name="OfflineLLM" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="MainFeature" Title="OfflineLLM" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <!-- WiX v4 native file harvesting: pulls in every file from the publish output,
           including OfflineLlm.App.exe, its dependencies, and engine\llama-server.exe. -->
      <Files Include="$(var.AppPublishDir)\**" />
    </ComponentGroup>

    <DirectoryRef Id="AppProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="7c1e4a3b-5e2a-4b8b-9a7d-1e3f2a4b5c61">
        <Shortcut Id="StartMenuShortcutEntry"
                  Name="OfflineLLM"
                  Description="Run a local LLM, saved or offline"
                  Target="[INSTALLFOLDER]OfflineLlm.App.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon.ico" />
        <RemoveFolder Id="RemoveAppProgramMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\OfflineLLM" Name="StartMenuShortcutInstalled"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="4b2e6a1d-8f3c-4a9e-b1d2-6a5c3e2f7b82">
        <Shortcut Id="DesktopShortcutEntry"
                  Name="OfflineLLM"
                  Description="Run a local LLM, saved or offline"
                  Target="[INSTALLFOLDER]OfflineLlm.App.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon.ico" />
        <RegistryValue Root="HKCU" Key="Software\OfflineLLM" Name="DesktopShortcutInstalled"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <Icon Id="AppIcon.ico" SourceFile="$(var.AppIcon)" />

    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <Property Id="ARPNOMODIFY" Value="1" />

  </Package>
</Wix>
